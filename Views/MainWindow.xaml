<Window
    x:Class="PhotoViewer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PhotoViewer.Models"
    mc:Ignorable="d"
    Title="My Modern Photo Viewer">

    <Grid>
        <Grid.Resources>
            <Style x:Key="HudButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#AA000000" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="8" />
            </Style>

            <Style x:Key="HudBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#AA000000" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="Opacity" Value="0" />
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="InfoPanelColumn" Width="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

            <Button x:Name="InfoButton" 
                    Click="InfoButton_Click"
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Margin="20"
                    Canvas.ZIndex="10"
                    ToolTipService.ToolTip="Bilgileri Göster/Gizle"
                    Style="{StaticResource HudButtonStyle}">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE946;"/>
            </Button>

            <Image x:Name="MainImage" 
                Source="{x:Bind ViewModel.DisplayImage, Mode=OneWay}" 
                Stretch="Uniform" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5"
                Margin="20"
                PointerWheelChanged="MainImage_PointerWheelChanged"
                PointerPressed="MainImage_PointerPressed"
                PointerMoved="MainImage_PointerMoved"
                PointerReleased="MainImage_PointerReleased"
                DoubleTapped="MainImage_DoubleTapped">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="ImageTransform" />
                </Image.RenderTransform>
            </Image>

            <!-- Zoom indicator (appears on zoom actions) -->
            <Border x:Name="ZoomIndicatorBorder"
                    Visibility="Collapsed"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="20,60,20,0"
                    Style="{StaticResource HudBorderStyle}">
                <TextBlock x:Name="ZoomIndicatorText"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Text="0%"/>
            </Border>
        </Grid>

        <Border x:Name="InfoPanel"
                Grid.Column="1" 
                Visibility="Collapsed"
                Background="{ThemeResource SystemControlAcrylicElementBrush}" 
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="1,0,0,0">
            <Grid Padding="20" Width="350">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="EXIF Detayları" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"/>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ExifMetadata}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ExifData">
                            <StackPanel Margin="0,5">
                                <TextBlock Text="{x:Bind Label}" 
                                           FontSize="12" 
                                           Foreground="Gray"/>
                                <TextBlock Text="{x:Bind Value}" 
                                           FontSize="14" 
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>